# NEUROAUTH v3.0.0 — Environment Variables
# Copie este arquivo como .env e preencha os valores.

# 1. Google Sheets — JSON da service account (inline, uma linha)
GOOGLE_SHEETS_CREDS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# 2. Spreadsheet ID (planilha mae)
SPREADSHEET_ID=1tId-AZorbeESHhlvOZei7_UbR0pMj0TMwsH0_lTCGLQ

# 3. API Key para autenticacao de chamadas
NEUROAUTH_API_KEY=sua-chave-secreta-aqui

# 4. Google OAuth Client ID (para validar tokens do frontend)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# 5. Google OAuth Client Secret (opcional, para server-side flow)
GOOGLE_CLIENT_SECRET=

# 6. Webhook Make.com (gerador de documentos — pode ficar vazio)
MAKE_DOC_WEBHOOK=
