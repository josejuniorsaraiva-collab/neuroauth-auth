# NEUROAUTH — variáveis de ambiente
# Copiar para o Render: Settings > Environment Variables
# NUNCA commitar o .env real no GitHub

# Gerar: openssl rand -hex 32
JWT_SECRET=

# Google Cloud Console > APIs > Credenciais > OAuth 2.0 Client IDs > Client ID
GOOGLE_CLIENT_ID=

# Google Cloud Console > Service Accounts > Chave JSON (conteúdo completo em uma linha)
GOOGLE_CREDENTIALS_JSON=

# Google Sheets: URL da planilha → docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=

# URL exata do GitHub Pages (sem barra final)
ALLOWED_ORIGINS=https://josejuniorsaraiva-collab.github.io

# Make.com — opcional para o primeiro shadow (pode deixar vazio)
MAKE_DOC_WEBHOOK=
MAKE_BILLING_WEBHOOK=
